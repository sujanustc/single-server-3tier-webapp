# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all manifest files submitting a sensitive set of variables
# Keep this file secure and private!
terraform.tfvars
terraform.tfvars.json

# Ignore override files as they may contain local overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include lock file if you want to lock provider versions
.terraform.lock.hcl
